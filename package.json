{
  "name": "pasarela-de-pago",
  "version": "0.1.0",
  "private": true,
  "description": "Base fundacional de una plataforma de payment orchestration para Colombia.",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "npm run dev --workspace @pasarela/web",
    "dev:web": "npm run dev --workspace @pasarela/web",
    "lint": "turbo run lint",
    "test": "turbo run test --continue",
    "test:e2e": "turbo run test:e2e --continue",
    "test:unit": "turbo run test:unit --continue",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.9.0",
    "supabase": "^2.90.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
